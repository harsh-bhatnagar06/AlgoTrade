# ============================================================
# AlgoForge — Environment Variable Template
# Copy this to .env and fill in your real values.
# ============================================================

NVIDIA_API_KEY=your_nvidia_nim_api_key_here
ANGEL_ONE_API_KEY=your_angel_one_api_key_here
PORT=5000

# Supabase (public config — base URL without /rest/v1/)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# NEVER add SUPABASE_SERVICE_ROLE_KEY to frontend or Firebase Hosting env

